// Views are mostly JS SFCs; stores/utils/api are TS. typecheck is soft (strict/checkJs off) until views migrate (P2-15).
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false /* views are JS SFCs; stores/utils are TS */,
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue", "vite.config.js"]
}
