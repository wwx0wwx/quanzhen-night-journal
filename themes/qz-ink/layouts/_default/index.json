{{- $.Scratch.Add "index" slice -}}
{{- range where .Site.RegularPages "Type" "in" .Site.Params.mainSections -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "permalink" .RelPermalink "summary" (.Params.summary | default .Summary | plainify) "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- if eq (len ($.Scratch.Get "index")) 0 -}}
  {{- range where .Site.RegularPages "Section" "posts" -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "permalink" .RelPermalink "summary" (.Params.summary | default .Summary | plainify) "date" (.Date.Format "2006-01-02")) -}}
  {{- end -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
