# 全真夜札引擎 - 环境配置示例
# 复制此文件为 .env 并填入真实值

# ==================== 项目路径配置 ====================

# 项目根目录（绝对路径）
ENGINE_ROOT=/opt/blog-src

# Hugo 静态站点输出目录
BLOG_OUTPUT_DIR=/var/www/shetop.ru

# 日志目录（默认：$ENGINE_ROOT/logs）
LOG_DIR=/opt/blog-src/logs

# ==================== OpenAI API 配置 ====================

# OpenAI API 密钥（必填）
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API 基础 URL（兼容 OpenAI 或兼容接口）
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# 使用的模型名称
OPENAI_MODEL=gpt-5.4

# ==================== 自动化配置 ====================

# 是否自动执行 git push（true/false）
# 启用前请确保已配置 git 远程仓库和 SSH 密钥
ENABLE_GIT_PUSH=false

# ==================== 调试配置（可选） ====================

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# API 请求超时时间（秒）
API_TIMEOUT=150

# 最大重试次数
MAX_RETRIES=3
