# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://ai.dooo.ng/v1/chat/completions
OPENAI_MODEL=gpt-5.4

# Paths (relative or absolute)
# ENGINE_ROOT: where this repo is cloned (e.g., /opt/blog-src or $HOME/quanzhen-night-journal)
ENGINE_ROOT=/opt/blog-src

# Blog Output: where generated posts are published (Hugo content directory)
BLOG_OUTPUT_DIR=/var/www/shetop.ru

# Optional: custom log directory (defaults to $ENGINE_ROOT/logs)
# LOG_DIR=/opt/blog-src/logs

# Runtime mode: auto | review-first | manual-only
# MODE=auto
