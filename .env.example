# ── Runtime ────────────────────────────────────────────
ENVIRONMENT=production

# REQUIRED for production — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ── Database ───────────────────────────────────────────
# Default SQLite works for single-server. Container path shown below.
DATABASE_URL=sqlite+aiosqlite:////app/data/quanzhen.db

# ── Site & Network ─────────────────────────────────────
# Public-facing URL (without trailing slash). Used as Hugo baseURL when no domain is configured.
SITE_BASE_URL=http://localhost:5210

# Server's public IP — needed for domain DNS verification and HTTPS certificate provisioning.
PUBLIC_SERVER_IP=

# Email for ACME (Let's Encrypt) certificate registration. Optional but recommended.
ACME_EMAIL=

# Allow Core to hot-reload Caddy config after domain changes.
CADDY_RELOAD_ENABLED=true
CADDY_RELOAD_URL=http://caddy:2019/load

# Enable if your domain goes through Cloudflare proxy (orange cloud).
ALLOW_CLOUDFLARE_PROXY_DOMAIN=false

# ── Paths (container defaults — adjust for local dev) ──
HUGO_CONTENT_DIR=/app/hugo/content
HUGO_PUBLIC_DIR=/app/hugo/public
BUILD_SIGNAL_FILE=/app/data/.build_signal
BUILD_STATUS_FILE=/app/data/build_status.json
PRESETS_DIR=/seed/presets
SEED_DRAFT_DIR=/seed/draft_review
AUTOMATION_DIR=/seed/automation

# ── Preset ─────────────────────────────────────────────
# Name of the persona preset to load on first setup. Ships with "quanzhen".
DEFAULT_PRESET=quanzhen

# ── Legacy & Debug ─────────────────────────────────────
IMPORT_LEGACY_ASSETS=false
ALLOW_FAKE_LLM=false

# ── LLM Tuning ─────────────────────────────────────────
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_REQUEST_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1

# ── CORS (comma-separated origins, empty = default) ────
CORS_ORIGINS=
